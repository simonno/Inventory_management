{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.9",
    "node": "20"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r requirements.txt",
        "cd frontend && npm install"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "cd frontend && npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn backend.src.main:app --host 0.0.0.0 --port $PORT"
  }
}
